<%@ page language="java" contentType="text/html; charset=UTF-8"
    pageEncoding="UTF-8"%>
<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Insert title here</title>
</head>
<body>
			<!-- 
					[HTML] 에서 사용되는 주석
			 -->		
		
			<%-- 
					[jsp] 에서 사용되는 주석
			--%>
			
			<%-- 
							
					[jsp] 란 [자바 서버 페이지] 의 약자이며,  jsp의 역활은  html 에서 아래 태그5개를 더사용할수있다.		
					     		  			
					     [1] 지시자(Directive) 태그        			<%@    %>
					     
					     [2] 표현식(Expression) 태그      			<%=    %>
					     
					     [3] 선언자(Declaration) 태그      	    	<%!    %>  (사용하지않는다)
					     
					     [4] 스크립트릿(Scriptlet) 태그  			<%     %>
					     
						 [5] 주석 태그                          			
			--%>

			<%--
					jsp 에서는 많은 기능이 있지만
						우리는 jsp 태그 4개 + 내장객체 4개 + 액션태그 1개로 웹사이트를 만들예정이다.
					
			 --%>
</body>
</html>